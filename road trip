<!DOCTYPE html>
<html lang="it">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="Road Trip">
<meta name="theme-color" content="#185FA5">
<title>Road Trip Agenda</title>

<link rel="apple-touch-icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><rect width='100' height='100' rx='20' fill='%23185FA5'/><text y='.9em' font-size='80' x='10'>🗺️</text></svg>">

<style>
*{box-sizing:border-box;-webkit-tap-highlight-color:transparent}

:root{
  --blue:#185FA5;
  --amber:#BA7517;
  --green:#3B6D11;
  --teal:#0F6E56;
  --pink:#D4537E;
  --purple:#534AB7;
  --bg:#f0f2f5;
  --card:#fff;
  --text:#1a1a1a;
  --muted:#666;
  --border:#e0e0e0;
  --radius:14px;
  --safe-top: env(safe-area-inset-top);
  --safe-bottom: env(safe-area-inset-bottom);
}

@media (prefers-color-scheme: dark){
  :root{
    --bg:#0f0f12;
    --card:#1c1c22;
    --text:#f0f0f0;
    --muted:#999;
    --border:#2e2e38;
  }
}

html,body{
  margin:0;padding:0;
  font-family:-apple-system,BlinkMacSystemFont,'Helvetica Neue',sans-serif;
  background:var(--bg);
  color:var(--text);
  min-height:100vh;
  -webkit-font-smoothing:antialiased;
}

/* ── HEADER ── */
.header{
  position:sticky;top:0;z-index:100;
  background:var(--blue);
  padding:calc(var(--safe-top) + 12px) 16px 12px;
  display:flex;align-items:center;justify-content:space-between;
  box-shadow:0 2px 12px rgba(0,0,0,.2);
}
.header h1{
  margin:0;font-size:18px;font-weight:600;color:#fff;
  letter-spacing:.3px;
}
.tab-pills{
  display:flex;gap:4px;
  background:rgba(255,255,255,.15);
  border-radius:20px;padding:3px;
}
.tab-pills button{
  border:none;background:transparent;color:rgba(255,255,255,.7);
  font-size:13px;font-weight:500;padding:5px 12px;border-radius:16px;
  cursor:pointer;transition:all .2s;
  -webkit-appearance:none;
}
.tab-pills button.active{
  background:#fff;color:var(--blue);
}

/* ── MAIN SCROLL ── */
.main{
  padding:12px 12px calc(var(--safe-bottom) + 80px);
  max-width:520px;margin:0 auto;
}

/* ── CARD GIORNO ── */
.day-card{
  background:var(--card);
  border-radius:var(--radius);
  margin-bottom:12px;
  overflow:hidden;
  border:1px solid var(--border);
}
.day-card-header{
  display:flex;align-items:center;gap:10px;
  padding:12px 14px 10px;
  border-bottom:1px solid var(--border);
}
.badge{
  width:32px;height:32px;border-radius:50%;
  display:flex;align-items:center;justify-content:center;
  color:#fff;font-size:13px;font-weight:700;
  flex-shrink:0;
}
.day-card-body{padding:12px 14px}

/* INPUT — font-size ≥16px per evitare zoom su iOS */
.field-row{
  display:flex;gap:8px;margin-bottom:10px;
}
input[type="text"],input[type="number"]{
  width:100%;
  font-size:16px;
  font-family:inherit;
  color:var(--text);
  background:var(--bg);
  border:1px solid var(--border);
  border-radius:10px;
  padding:10px 12px;
  outline:none;
  -webkit-appearance:none;
  transition:border-color .15s;
}
input[type="text"]:focus,input[type="number"]:focus{
  border-color:var(--blue);
}
.title-input{
  font-weight:600;flex:1;
  background:transparent;border:none;
  border-bottom:1px solid var(--border);
  border-radius:0;padding:4px 0;font-size:16px;
}
.title-input:focus{border-bottom-color:var(--blue)}

.cost-input{width:90px;flex-shrink:0}

/* TAGS */
.tags-row{
  display:flex;flex-wrap:wrap;gap:6px;
  margin-bottom:12px;
}
.tag{
  display:inline-flex;align-items:center;
  padding:6px 12px;
  border-radius:20px;
  font-size:14px;
  border:1px solid var(--border);
  color:var(--muted);
  cursor:pointer;
  background:var(--bg);
  transition:all .15s;
  -webkit-user-select:none;user-select:none;
  min-height:36px;
}
.tag.active{
  background:var(--blue);color:#fff;border-color:var(--blue);
}

/* ATTIVITÀ */
.activity-row{
  display:flex;align-items:center;gap:8px;
  margin-bottom:8px;
}
.activity-time{width:72px;flex-shrink:0}
.activity-text{flex:1}
.icon-btn{
  width:36px;height:36px;
  border:none;background:transparent;
  color:var(--muted);font-size:18px;
  cursor:pointer;border-radius:8px;
  display:flex;align-items:center;justify-content:center;
  flex-shrink:0;transition:background .15s;
  -webkit-appearance:none;
}
.icon-btn:active{background:var(--border)}

/* SMALL BUTTONS */
.small-btn{
  display:inline-flex;align-items:center;gap:5px;
  padding:8px 14px;border-radius:10px;
  font-size:14px;font-family:inherit;
  border:1px dashed var(--border);
  background:transparent;color:var(--muted);
  cursor:pointer;-webkit-appearance:none;
  margin-right:8px;margin-top:4px;
  min-height:36px;
}
.small-btn:active{background:var(--border)}
.danger-btn{
  border-color:transparent;color:#c44;
}

/* FAB */
.fab{
  position:fixed;
  bottom:calc(var(--safe-bottom) + 20px);
  right:20px;
  width:56px;height:56px;
  border-radius:28px;
  background:var(--blue);
  color:#fff;font-size:28px;
  border:none;cursor:pointer;
  box-shadow:0 4px 16px rgba(24,95,165,.4);
  display:flex;align-items:center;justify-content:center;
  -webkit-appearance:none;
  transition:transform .15s;
  z-index:50;
}
.fab:active{transform:scale(.93)}

/* ── AGENDA VIEW ── */
.agenda-card{
  background:var(--card);
  border-radius:var(--radius);
  margin-bottom:12px;
  overflow:hidden;
  border:1px solid var(--border);
}
.agenda-header{
  display:flex;align-items:center;gap:10px;
  padding:12px 14px;
}
.agenda-meta{font-size:13px;color:var(--muted);margin-top:2px}
.agenda-body{
  padding:0 14px 14px;
}
.agenda-tags{display:flex;flex-wrap:wrap;gap:5px;margin-bottom:10px}
.agenda-tag{
  background:var(--bg);border:1px solid var(--border);
  border-radius:20px;padding:4px 10px;font-size:12px;color:var(--muted);
}
.agenda-item{
  display:flex;align-items:baseline;gap:8px;
  padding:6px 0;
  border-top:1px solid var(--border);
}
.agenda-time{
  font-size:13px;font-weight:600;color:var(--blue);
  min-width:44px;
}
.agenda-text{font-size:15px}

/* ── TOAST ── */
.toast{
  position:fixed;bottom:calc(var(--safe-bottom) + 90px);left:50%;
  transform:translateX(-50%);
  background:#333;color:#fff;
  padding:10px 18px;border-radius:20px;
  font-size:14px;opacity:0;
  transition:opacity .3s;pointer-events:none;
  z-index:200;white-space:nowrap;
}
.toast.show{opacity:1}

/* ── INSTALL BANNER ── */
.install-banner{
  background:var(--blue);color:#fff;
  padding:12px 14px;
  display:flex;align-items:center;justify-content:space-between;
  gap:10px;
}
.install-banner p{margin:0;font-size:13px;line-height:1.4;flex:1}
.install-close{
  background:rgba(255,255,255,.2);border:none;
  color:#fff;width:28px;height:28px;border-radius:50%;
  font-size:16px;cursor:pointer;flex-shrink:0;
  display:flex;align-items:center;justify-content:center;
}
</style>
</head>

<body>

<div class="header">
  <h1>🗺️ Road Trip</h1>
  <div class="tab-pills">
    <button id="btnEdit" class="active" onclick="setMode('edit')">✏️ Modifica</button>
    <button id="btnView" onclick="setMode('view')">📖 Agenda</button>
  </div>
</div>

<div id="installBanner" style="display:none" class="install-banner">
  <p>Aggiungi alla schermata Home: tocca <b>⎋ Condividi</b> → <b>Aggiungi alla schermata Home</b></p>
  <button class="install-close" onclick="dismissBanner()">✕</button>
</div>

<div class="main" id="app"></div>
<div class="toast" id="toast"></div>

<script>
const COLORS=["#185FA5","#BA7517","#3B6D11","#0F6E56","#D4537E","#534AB7"];
const TAGS=["Guida","Bagno","Trekking","Campeggio","Kayak","Isola","Rientro","Spesa"];

let mode="edit";

/* ── STORAGE ROBUSTO ── */
function storageGet(k){
  try{return JSON.parse(localStorage.getItem(k))}catch(e){return null}
}
function storageSet(k,v){
  try{localStorage.setItem(k,JSON.stringify(v));return true}catch(e){return false}
}

let days=storageGet("agenda_days");
if(!days){
  days=[{title:"Giorno 1",loc:"",cost:"",tags:[],items:[{t:"",text:""}]}];
}

function save(){
  if(!storageSet("agenda_days",days)){
    showToast("Spazio esaurito, i dati potrebbero non salvarsi");
  }
}

/* ── TOAST ── */
let toastTimer;
function showToast(msg){
  const t=document.getElementById("toast");
  t.textContent=msg;t.classList.add("show");
  clearTimeout(toastTimer);
  toastTimer=setTimeout(()=>t.classList.remove("show"),2000);
}

/* ── INSTALL BANNER (solo Safari iOS) ── */
const isIOS=/iphone|ipad|ipod/i.test(navigator.userAgent);
const isStandalone=window.navigator.standalone;
const bannerDismissed=storageGet("banner_dismissed");
if(isIOS&&!isStandalone&&!bannerDismissed){
  document.getElementById("installBanner").style.display="flex";
}
function dismissBanner(){
  document.getElementById("installBanner").style.display="none";
  storageSet("banner_dismissed",true);
}

/* ── MODE ── */
function setMode(m){
  mode=m;
  document.getElementById("btnEdit").classList.toggle("active",m==="edit");
  document.getElementById("btnView").classList.toggle("active",m==="view");
  render();
}

/* ── RENDER ── */
function render(){
  const app=document.getElementById("app");
  app.innerHTML="";

  days.forEach((d,i)=>{
    const color=COLORS[i%COLORS.length];

    if(mode==="view"){
      const el=document.createElement("div");
      el.className="agenda-card";
      el.innerHTML=`
        <div class="agenda-header">
          <div class="badge" style="background:${color}">${i+1}</div>
          <div>
            <div style="font-weight:600;font-size:16px">${esc(d.title)}</div>
            <div class="agenda-meta">${esc(d.loc)}${d.cost?` · ${esc(d.cost)}€`:""}</div>
          </div>
        </div>
        <div class="agenda-body">
          ${d.tags.length?`<div class="agenda-tags">${d.tags.map(t=>`<span class="agenda-tag">${esc(t)}</span>`).join("")}</div>`:""}
          ${d.items.filter(it=>it.t||it.text).map(it=>`
            <div class="agenda-item">
              <span class="agenda-time">${esc(it.t)}</span>
              <span class="agenda-text">${esc(it.text)}</span>
            </div>
          `).join("")}
        </div>
      `;
      app.appendChild(el);
      return;
    }

    // EDIT MODE
    const el=document.createElement("div");
    el.className="day-card";

    const itemsHTML=d.items.map((it,j)=>`
      <div class="activity-row">
        <input class="activity-time" type="text" placeholder="ora" value="${esc(it.t)}"
          onchange="days[${i}].items[${j}].t=this.value;save()">
        <input class="activity-text" type="text" placeholder="attività" value="${esc(it.text)}"
          onchange="days[${i}].items[${j}].text=this.value;save()">
        <button class="icon-btn" onclick="removeItem(${i},${j})" title="Rimuovi">✕</button>
      </div>
    `).join("");

    el.innerHTML=`
      <div class="day-card-header">
        <div class="badge" style="background:${color}">${i+1}</div>
        <input class="title-input" type="text" value="${esc(d.title)}"
          onchange="days[${i}].title=this.value;save()">
        <button class="icon-btn danger-btn" onclick="removeDay(${i})" title="Elimina giorno">🗑</button>
      </div>
      <div class="day-card-body">
        <div class="field-row">
          <input type="text" placeholder="luogo" value="${esc(d.loc)}"
            onchange="days[${i}].loc=this.value;save()">
          <input class="cost-input" type="number" placeholder="€" value="${esc(d.cost)}"
            onchange="days[${i}].cost=this.value;save()">
        </div>

        <div class="tags-row">
          ${TAGS.map(t=>`
            <span class="tag ${d.tags.includes(t)?"active":""}"
              onclick="toggleTag(${i},'${t}')">${t}</span>
          `).join("")}
        </div>

        ${itemsHTML}

        <button class="small-btn" onclick="addItem(${i})">+ attività</button>
      </div>
    `;
    app.appendChild(el);
  });

  if(mode==="edit"){
    const fab=document.createElement("button");
    fab.className="fab";
    fab.title="Aggiungi giorno";
    fab.innerHTML="+";
    fab.onclick=addDay;
    document.body.appendChild(fab);
  } else {
    // rimuovi FAB se presente
    const old=document.querySelector(".fab");
    if(old)old.remove();
  }
}

function esc(s){
  return String(s||"").replace(/&/g,"&amp;").replace(/"/g,"&quot;").replace(/</g,"&lt;").replace(/>/g,"&gt;");
}

/* ── AZIONI ── */
function addDay(){
  days.push({title:"Giorno "+(days.length+1),loc:"",cost:"",tags:[],items:[{t:"",text:""}]});
  save();render();
  showToast("Giorno aggiunto");
  setTimeout(()=>window.scrollTo({top:document.body.scrollHeight,behavior:"smooth"}),50);
}
function removeDay(i){
  if(days.length===1){showToast("Almeno un giorno richiesto");return}
  days.splice(i,1);save();render();showToast("Giorno rimosso");
}
function addItem(i){
  days[i].items.push({t:"",text:""});
  save();render();
}
function removeItem(i,j){
  days[i].items.splice(j,1);
  save();render();
}
function toggleTag(i,tag){
  const d=days[i];
  const idx=d.tags.indexOf(tag);
  if(idx>-1)d.tags.splice(idx,1);
  else d.tags.push(tag);
  save();render();
}

render();
</script>
</body>
</html>
